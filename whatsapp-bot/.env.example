# ============================================================
#  WhatsApp Gatekeeper Bot — Contoh Environment Variables
#  Salin file ini ke .env (untuk lokal) atau set langsung di Railway
# ============================================================

# Nomor WhatsApp yang dipakai bot (tanpa +, tanpa spasi) — WAJIB diisi
# Contoh: 6285186655283  →  nomor Indonesia dengan kode negara
NOMOR_BOT=628xxxxxxxxxx

# Path folder penyimpanan sesi autentikasi WhatsApp.
# Default: auth_info_baileys (di direktori yang sama dengan index.js)
#
# Di Railway TANPA volume → biarkan default (sesi hilang saat redeploy, perlu pairing ulang)
# Di Railway DENGAN volume → set ke path mount volume agar sesi persisten
# Contoh dengan Railway Volume mount di /data:
# AUTH_DIR=/data/auth
AUTH_DIR=auth_info_baileys
