# ============================================================
#  WhatsApp Gatekeeper Bot v2 — Contoh Environment Variables
#  Salin file ini ke .env (untuk lokal) atau set langsung di Railway
# ============================================================

# ── WAJIB ──────────────────────────────────────────────────
# Nomor WhatsApp yang dipakai bot (tanpa +, tanpa spasi)
# Contoh: 6285186655283
NOMOR_BOT=628xxxxxxxxxx

# ── AI (Sangat Dianjurkan) ─────────────────────────────────
# API Key Gemini AI dari https://aistudio.google.com/app/apikey
# Jika diisi: tamu berbicara dengan Gemini AI terlebih dahulu
# Jika kosong: langsung masuk skrining 3 langkah biasa
GEMINI_API_KEY=

# ── OPSIONAL ───────────────────────────────────────────────
# Path folder sesi autentikasi WhatsApp
# Default: auth_info_baileys
# Di Railway DENGAN volume → set ke path mount volume
# Contoh: AUTH_DIR=/data/auth
AUTH_DIR=auth_info_baileys

# Nama persona bot saat memperkenalkan diri
NAMA_BOT=Islah

# Nama keluarga/rumah yang disebutkan bot
NAMA_KELUARGA=Dil Familie
